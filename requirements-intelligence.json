{
  "name": "Requirements Intelligence",
  "nodes": [
    {
      "id": "Sticky_Overview",
      "name": "Sticky_Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        40,
        40
      ],
      "parameters": {
        "content": "REQUIREMENTS INTELLIGENCE\\nInput: public product feedback (App Store / Play Store reviews, GitHub issues).\\n5 steps: extract, cluster, prioritize, draft user stories, acceptance criteria.\\nEach HTTP node retries 3x (rate limit / transient error handling).\\nFinal output is schema-validated, then a PM must approve via Discord before it's logged. AI never finalizes.",
        "height": 200,
        "width": 620,
        "color": 4
      }
    },
    {
      "id": "Manual_Trigger",
      "name": "Manual_Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        40,
        300
      ],
      "parameters": {}
    },
    {
      "id": "Define_Input",
      "name": "Define_Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        300,
        300
      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "Define_Input-0",
              "name": "feedbackText",
              "value": "={{$json.feedbackText}}",
              "type": "string"
            },
            {
              "id": "Define_Input-1",
              "name": "source",
              "value": "app_store_reviews",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "Step1_Extract_Requirements",
      "name": "Step1_Extract_Requirements",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.ANTHROPIC_API_KEY}}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({model: 'claude-sonnet-4-6', max_tokens: 1500, messages: [{ role: 'user', content: 'Extract discrete requirement statements from this feedback. Return JSON array only.\\n\\n' + $json.feedbackText }]}) }}",
        "options": {
          "timeout": 60000
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "onError": "continueErrorOutput",
      "notes": "Retries 3x on failure (covers rate limits / transient API errors). See docs/decisions-and-tradeoffs.md."
    },
