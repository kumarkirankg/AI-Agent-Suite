    {
      "id": "ReqIntel_Validate_Schema",
      "name": "ReqIntel_Validate_Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1860,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nlet parsed, valid = true, reason = '';\ntry {\n  const text = $input.first().json.content?.[0]?.text || $input.first().json.body?.content?.[0]?.text || '{}';\n  parsed = JSON.parse(text);\n  if (!Array.isArray(parsed) && !parsed.stories) { valid = false; reason = 'missing stories array'; }\n} catch (e) { valid = false; reason = 'invalid JSON: ' + e.message; parsed = null; }\nreturn [{ json: { valid, reason, stories: parsed } }];\n"
      },
      "notes": "Parses the last step's JSON, checks it against the expected schema, sets valid=true/false."
    },
    {
      "id": "ReqIntel_Schema_Valid",
      "name": "ReqIntel_Schema_Valid",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2120,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "ReqIntel_Schema_Valid-cond",
              "leftValue": "={{$json.valid}}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "ReqIntel_Log_Validation_Failure",
      "name": "ReqIntel_Log_Validation_Failure",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2380,
        480
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{ json: { status: 'validation_failed', reason: $json.reason, timestamp: new Date().toISOString() } }];"
      },
      "notes": "Terminal node: 3 retries already happened at the HTTP Request level. This logs the final failure for manual review."
    },
    {
      "id": "ReqIntel_Notify_Reviewer",
      "name": "ReqIntel_Notify_Reviewer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2380,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{$env.DISCORD_WEBHOOK_URL}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content: 'New user stories pending review: ' + JSON.stringify($json.stories).slice(0,300) }) }}"
      },
      "notes": "Posts the pending recommendation + the Wait node's resume URL to a free Discord webhook channel."
    },
    {
      "id": "ReqIntel_Wait_For_Approval",
      "name": "ReqIntel_Wait_For_Approval",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2640,
        300
      ],
      "parameters": {
        "resume": "webhook",
        "webhookSuffix": "={{$workflow.id}}-ReqIntel_Wait_For_Approval"
      },
      "webhookId": "ReqIntel_Wait_For_Approval-webhook",
      "notes": "Pauses here until the human reviewer's approve/reject click POSTs back to this node's webhook URL."
    },
    {
      "id": "ReqIntel_Approved",
      "name": "ReqIntel_Approved",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2900,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "ReqIntel_Approved-cond",
              "leftValue": "={{$json.body.decision}}",
              "rightValue": "approve",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "ReqIntel_Log_Rejected",
      "name": "ReqIntel_Log_Rejected",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3160,
        480
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{ json: { status: 'rejected_by_human', timestamp: new Date().toISOString() } }];"
      }
    },
    {
      "id": "ReqIntel_Log_Approved_Output",
      "name": "ReqIntel_Log_Approved_Output",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        3160,
